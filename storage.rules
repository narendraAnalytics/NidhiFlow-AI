rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Loan documents: authenticated only. Cannot yet restrict by loan
    // ownership — the backend has no Firebase Admin token verification or
    // custom claims to check "does this user own this loan" against.
    // Close this gap once backend auth verification exists.
    match /loan-documents/{loanId}/{docType}/{fileName} {
      allow read, write: if request.auth != null;
    }

    match /test-uploads/{uid}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
